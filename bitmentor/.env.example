# ───────────────────────────────────────────────────────────────
#  MentorPilot — fichier de configuration
#  Copie ce fichier vers .env puis remplis les valeurs :
#      cp .env.example .env
# ───────────────────────────────────────────────────────────────

# ── DeepSeek (modèle IA) ────────────────────────────────────────
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXX
# Optionnel (valeurs par défaut) :
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# ── Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=XXXXXXXXXXXXXXXXXXXXXXXXX

# ── Apprentissage ───────────────────────────────────────────────
# Heure (0-23) du push de la leçon quotidienne, interprétée dans le
# fuseau TZ ci-dessous.
LESSON_HOUR=9
# Chemin du fichier d'état (roadmap + progression).
# STATE_PATH=./state.json

# ── Fuseau horaire ──────────────────────────────────────────────
# IMPORTANT en Docker : sans ça le conteneur est en UTC et la leçon
# arriverait à la mauvaise heure. Mets TON fuseau (ex : Europe/Paris).
TZ=Europe/Paris
